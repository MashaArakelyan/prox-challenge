{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".next",
    "esModuleInterop": true
  },
  "include": ["scripts", "lib"],
  "exclude": ["node_modules", ".next"]
}
